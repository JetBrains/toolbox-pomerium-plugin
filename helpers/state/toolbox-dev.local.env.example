# Dev Toolbox / source-built Toolbox settings. Copy to:
#   helpers/state/toolbox-dev.local.env
#
# This file is loaded after manage.local.env and before local-idea.local.env.
# Keep non-dev runs free of these values by not copying this file.

TOOLBOX_MODE='toolbox-dev'
TBCLI_SOURCE_MODE='auto'

# Legacy override.
# Set to 1 to force host tbcli or 0 to force downloaded Linux tbcli.
# Leave unset when TBCLI_SOURCE_MODE is enough.
USE_HOST_TBCLI=''

# Optional explicit tbcli path overrides auto-discovery.
# Accepts:
#   - tbcli root containing bin/tbcli
#   - bin directory containing tbcli
#   - direct path to the tbcli executable
HOST_TBCLI_SOURCE_PATH=''

# Optional search root for auto-discovering source-built tbcli when
# HOST_TBCLI_SOURCE_PATH is empty.
HOST_TBCLI_SEARCH_ROOT="$HOME/Library/Caches/*"

# Optional local tbcli-agent helper overrides.
TBCLI_PLATFORM_SUFFIX='mac-aarch64'
LOCAL_TBCLI_CACHE_DIR=''
LOCAL_TBCLI_PATH=''
