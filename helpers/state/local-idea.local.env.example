# Local IDEA / source-built IDE settings. Copy to:
#   helpers/state/local-idea.local.env
#
# This file is loaded last, so local IDEA paths can override common defaults.
# Do not copy this file for non-dev runs.

# Optional unpacked Linux IDEA dist directory.
# If set, manage.sh stages it for Docker and overlays sibling dist.all
# automatically when present.
HOST_IDEA_DIST_DIR=''

# Optional directory containing Linux aarch64 IDEA build artifacts like:
#   ideaIU-262.SNAPSHOT-aarch64.tar.gz
#   ideaIU-262.SNAPSHOT-aarch64.sit
HOST_IDEA_ARTIFACTS_DIR=''

# Optional explicit archive override if you do not want auto-discovery inside
# HOST_IDEA_ARTIFACTS_DIR.
HOST_IDEA_DIST_ARCHIVE=''

# Optional host project directory to copy into the Docker container at startup.
HOST_PROJECT_DIR=''

# Optional destination path for the copied project inside the Docker container.
CONTAINER_PROJECT_DIR='/home/dev/projects/test_project'

# Build number for cb=... inside connectionKey.
CONNECTION_KEY_BUILD='261.24374.151'

# Optional local macOS IDEA dist for registering it in local Toolbox.
LOCAL_TOOLBOX_IDE_DIST_DIR=''

# Optional explicit Toolbox app source for install-local-toolbox-ide.sh.
LOCAL_TOOLBOX_APP_SOURCE_PATH=''
